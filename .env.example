# ============================================================
# CONFIGURACIÓN DEL SERVIDOR HOSTING v21 — Oracle VPS Free ARM64
# Copia este archivo a .env y edita todos los valores
# O ejecuta: bash scripts/setup-env.sh  (genera todo automáticamente)
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
SERVER_IP=1.2.3.4
DOMAIN=tudominio.com
INSTALL_DIR=/opt/hosting
TZ=America/Lima

# ── SSL / Let's Encrypt ───────────────────────────────────────
ACME_EMAIL=admin@tudominio.com
ACME_ENV=production

# ── Wildcard SSL — Cloudflare DNS Challenge (Feature #2) ─────
# Solo necesario si usas letsencrypt-wildcard en labels de Traefik
# Obtén el token en: https://dash.cloudflare.com/profile/api-tokens
# Permisos requeridos: Zone:DNS:Edit
CF_DNS_API_TOKEN=

# ── PowerDNS ─────────────────────────────────────────────────
PDNS_API_KEY=cambia_esta_api_key_por_algo_seguro_64chars
PDNS_ADMIN_SECRET_KEY=otro_secreto_flask_independiente_64chars
PDNS_API_PORT=8053
PDNS_ADMIN_PORT=8081

# ── Base de Datos ─────────────────────────────────────────────
DB_ROOT_PASS=cambia_root_password_muy_segura_aqui
PDNS_DB_NAME=powerdns
PDNS_DB_USER=pdns
PDNS_DB_PASS=pdns_password_segura
PDNS_ADMIN_DB_NAME=pdnsadmin
PDNS_ADMIN_DB_USER=pdnsadmin
PDNS_ADMIN_DB_PASS=pdnsadmin_password_segura
DB_USER=webuser
DB_PASS=cambia_web_db_password_aqui

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASS=cambia_redis_password_aqui

# ── Traefik ───────────────────────────────────────────────────
# Generar con: htpasswd -nbB admin tupassword
TRAEFIK_AUTH=admin:$$2y$$05$$cambiar_este_hash_con_htpasswd

# ── SFTPGo (Feature #1) ───────────────────────────────────────
# Generado automáticamente al ejecutar: ./scripts/sftp-user.sh - - setup
# Puerto SFTP: 2022 (TCP) — debe estar abierto en Oracle Cloud firewall
SFTPGO_ADMIN_PASS=
SFTPGO_MEM=128m
SFTPGO_CPU=0.10

# ── Mailcow (Feature #3) ──────────────────────────────────────
# Configurado por: ./scripts/setup-mailcow.sh
# Requiere ~2-3GB RAM adicional
MAIL_DOMAIN=mail.tudominio.com
# setup-env.sh genera esto automáticamente como mail.$DOMAIN

# ── Límites de recursos Docker ────────────────────────────────
TRAEFIK_MEM=128m
TRAEFIK_CPU=0.10
PDNS_MEM=128m
PDNS_CPU=0.10
PDNS_ADMIN_MEM=256m
PDNS_ADMIN_CPU=0.20
NGINX_MEM=256m
NGINX_CPU=0.30
PHP_MEM=512m
PHP_CPU=0.50
MARIADB_MEM=512m
MARIADB_CPU=0.50
REDIS_MEM=128m
REDIS_CPU=0.10
PORTAINER_MEM=128m
PORTAINER_CPU=0.10

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=/opt/hosting/data/backups
BACKUP_RETENTION_DAYS=7

# ── Alertas (monitor.sh y backup.sh) ─────────────────────────
# Telegram: crea un bot con @BotFather, obtén el chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook genérico (Slack, Discord, n8n, Make, etc.)
ALERT_WEBHOOK_URL=

# ── Backup Offsite con rclone ─────────────────────────────────
# Configurar primero: rclone config
# Proveedores soportados: S3, Backblaze B2, Google Drive, Dropbox, SFTP, etc.
# Ejemplos:
#   RCLONE_REMOTE=s3:mi-bucket/hosting-backups
#   RCLONE_REMOTE=b2:mi-bucket/backups
#   RCLONE_REMOTE=gdrive:backups/hosting
RCLONE_REMOTE=

# ── SERVER_DOMAIN — dominio propio del servidor (para NS records) ──
# Si tu servidor es servidor de nombres para otros dominios,
# este es el dominio donde están ns1/ns2
# Por defecto usa el mismo DOMAIN
SERVER_DOMAIN=

# ── Registro CAA ─────────────────────────────────────────────
# add-domain.sh añade automáticamente: CAA 0 issue "letsencrypt.org"
# No requiere configuración adicional aquí.
